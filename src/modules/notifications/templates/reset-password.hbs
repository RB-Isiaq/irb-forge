{{#> layout}}
<tr>
  <td>
    <h2 class="text-primary" style="margin:0 0 12px;">Reset your password</h2>

    <p class="text-secondary" style="line-height:1.6;">
      We received a request to reset your password.
      Click the button below to proceed. This link expires in <strong>15 minutes</strong>.
    </p>

    {{> button url=resetUrl text="Reset Password"}}

    <p class="text-muted" style="font-size:12px; line-height:1.6; margin-top:8px;">
      If the button doesn't work, copy and paste this link into your browser:
    </p>
    <p style="
      font-family: 'Courier New', Courier, monospace;
      font-size: 12px;
      word-break: break-all;
      padding: 10px 14px;
      border-radius: 6px;
      border: 1px solid #D1D5DB;
      margin: 4px 0 0;
    " class="code-block text-muted">{{resetUrl}}</p>
  </td>
</tr>
{{/layout}}
