{{#> layout}}
<tr>
  <td>
    <h2 class="text-primary" style="margin:0 0 12px;">
      Payment Confirmed
    </h2>

    <p class="text-secondary" style="line-height:1.6;">
      Your payment for <strong>{{orgName}}</strong> has been processed successfully.
      Your organization is now on the <strong>Pro plan</strong>.
    </p>

    <table style="width:100%;border-collapse:collapse;margin:20px 0;background:#f9fafb;border-radius:8px;">
      <tr>
        <td style="padding:12px 16px;color:#6b7280;font-size:14px;">Amount</td>
        <td style="padding:12px 16px;font-weight:600;text-align:right;">{{amount}}</td>
      </tr>
      <tr style="border-top:1px solid #e5e7eb;">
        <td style="padding:12px 16px;color:#6b7280;font-size:14px;">Date</td>
        <td style="padding:12px 16px;font-weight:600;text-align:right;">{{date}}</td>
      </tr>
      <tr style="border-top:1px solid #e5e7eb;">
        <td style="padding:12px 16px;color:#6b7280;font-size:14px;">Plan</td>
        <td style="padding:12px 16px;font-weight:600;text-align:right;">IRB Forge Pro</td>
      </tr>
    </table>

    <p class="text-muted" style="font-size:13px;line-height:1.6;">
      Questions about your billing? Reply to this email and we'll help you out.
    </p>
  </td>
</tr>
{{/layout}}
