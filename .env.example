# App
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/irb_forge

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Mail
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
# Optional: URL to a publicly hosted PNG of the IRB Forge logo (2× resolution, e.g. 280×72px).
# When set, emails use the image. When unset, emails fall back to the inline HTML table logo.
# Example: https://your-cdn.com/irb-forge-logo.png
LOGO_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=  # get from: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_PRO_PRICE_ID=    # create a Product + Price in Stripe dashboard, paste the price_xxx ID here

# Google OAuth
GOOGLE_CLIENT_ID=

# Frontend
FRONTEND_URL=http://localhost:3001

# CORS — comma-separated list of allowed origins (defaults to FRONTEND_URL if not set)
# CORS_ORIGINS=https://app.irb-forge.com,https://admin.irb-forge.com
